# Phase 2-A.2 Step 4b template — fill the EXR paths after AE Render Queue
# emits the 14-frame pair, then run:
#
#   tests/.venv/bin/python3 tests/capture_32bpc.py \
#       --config tests/capture_config_32bpc.toml --verbose
#
# How to read this file:
#   * `range`       is the raw PARAM_RANGE slider value (0..100, float).
#                   The numbers below are reverse-derived from the v1.4.0
#                   u32-range goldens (slider ≈ u32 * 100 / (max_value * 4)).
#                   If you remember the original "nice" slider value used
#                   in the v1.4.0 capture (e.g. 1.0 instead of 0.9804),
#                   prefer the original — it produces a cleaner reference.
#   * `line_weight` is the raw PARAM_LINE_WEIGHT slider value (0..1).
#   * `white`       is the PARAM_WHITE_OPTION checkbox state.
#   * `in_exr` / `out_exr` are paths under `exr_base_dir`, one per frame.
#
# The 14 frames here intentionally mirror the v1.4.0-ae2025 manifest so
# both suites can later be compared on the same scenes (one capture in
# the integer domain, one in f32).
#
# Copy this file to `tests/capture_config_32bpc.toml` (NOT committed) and
# edit. The template itself stays committed as the canonical schema.

# Where AE wrote the EXRs. Adjust to the actual Render Queue output dir.
exr_base_dir = "/tmp/exr_32bpc"
# Where SMDP fixtures get written. Stays the same — manifest.toml will
# live in this directory.
output_dir   = "tests/goldens/v1.6.0-32bpc"

[[frames]]
n = 0
range  = 0.9804      # v1.4.0 u32_range=10 (8bpc); operator likely typed 1.0
line_weight = 0.500000
white  = false
in_exr  = "input_0000.exr"
out_exr = "output_0000.exr"

